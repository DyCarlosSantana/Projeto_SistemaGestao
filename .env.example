# Dycore — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA suba o arquivo .env para o GitHub

# ─── CONFIGURAÇÕES DA APLICAÇÃO ───────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=1
FLASK_PORT=5000

# ─── SEGURANÇA JWT ────────────────────────────────────────────────────────────
# Gere uma chave segura com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=substitua-por-uma-chave-secreta-forte-aqui
JWT_SECRET_KEY=substitua-por-outra-chave-secreta-forte-aqui
JWT_ACCESS_TOKEN_EXPIRES_HOURS=8

# ─── BANCO DE DADOS ───────────────────────────────────────────────────────────
# SQLite (desenvolvimento local)
DATABASE_URL=sqlite:///dycore.db

# PostgreSQL (produção — Fase 4)
# DATABASE_URL=postgresql://usuario:senha@localhost:5432/dycore

# ─── PAGAR.ME (Fase 6) ────────────────────────────────────────────────────────
# PAGARME_API_KEY=ak_live_xxxxxxxxxxxxxxxx
# PAGARME_ENCRYPTION_KEY=ek_live_xxxxxxxxxxxxxxxx
# PAGARME_WEBHOOK_SECRET=xxxxxxxxxxxxxxxx
